BOT_TOKEN=вставь_сюда_свой_токен_от_BotFather

# Твой личный Telegram user_id — сюда придут уведомления, если бот упадёт
# с ошибкой. Узнать: напиши @userinfobot в Telegram, он пришлёт твой ID.
ADMIN_CHAT_ID=вставь_сюда_свой_числовой_id

# ---------- Интеграция с сайтом mashinabodystore.ru ----------
# Все три значения ниже предоставляет Фёдор (техспециалист сайта).
# Пока их нет — оформление заказа будет возвращать ошибку, это ожидаемо.

# Эндпоинт создания заказа. Фёдор предупредил, что URL может измениться —
# если поменяется, обновить только это значение, код трогать не нужно.
SITE_ORDER_ENDPOINT=https://mashinabodystore.ru/wp-json/v2/integrations/musculata

# Эндпоинт оплаты подписки "Орден" — ЕЩЁ НЕ СОГЛАСОВАН с Фёдором.
# Пока пусто — кнопка "Оплатить подписку" будет честно показывать
# пользователю, что раздел временно недоступен, вместо ошибки.
SITE_SUBSCRIPTION_ENDPOINT=

# Секрет, который бот отправляет сайту в заголовке X-Bot-Token
# при создании заказа. Фёдор пришлёт, когда интеграция будет готова
# на его стороне.
X_BOT_TOKEN=ждём_от_фёдора

# Секрет, которым сайт подписывает вебхуки (X-WP-Secret) — missing-items
# и payment-success. Тоже ждём от Фёдора.
X_WP_SECRET=ждём_от_фёдора

# Порт, на котором веб-сервер вебхуков (webhooks.py / run.py) слушает
# входящие запросы от сайта. Фёдору нужно будет сообщить публичный
# адрес вида https://твой-домен-или-ip:PORT/webhook/...
WEBHOOK_PORT=5000
